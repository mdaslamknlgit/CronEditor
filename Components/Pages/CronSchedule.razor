@page "/cron-schedule"
@inject CronBuilderService CronService

<div class="schedule-container">
    <h2>Saved Schedules</h2>

    <!-- Use the new Cron Expression Editor -->
    <div class="editor-wrapper">
        <h3>Build Your Cron Expression</h3>
        <CronExpressionEditor InitialExpression="@SelectedExpression" OnExpressionChanged="@OnExpressionSelected" />
    </div>

    <!-- Add to Schedules Section -->
    <div class="add-schedule-section">
        <h3>Add to Schedule</h3>
        <div class="form-group">
            <label>Schedule Name:</label>
            <input type="text" class="form-control" @bind="ScheduleName" placeholder="e.g., Daily Backup" />
        </div>
        @if (!string.IsNullOrEmpty(AddError))
        {
            <div class="alert alert-danger">@AddError</div>
        }
        <button class="btn btn-primary" @onclick="AddSchedule">Add Schedule</button>
    </div>

    <!-- Rest of the component remains the same -->
    @if (Schedules.Count > 0)
    {
        <div class="schedules-list">
            <h3>Your Schedules (@Schedules.Count)</h3>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Expression</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var schedule in Schedules)
                        {
                            <tr>
                                <td>@schedule.Name</td>
                                <td><code>@schedule.Expression</code></td>
                                <td>@CronService.GetCronDescription(schedule.Expression)</td>
                                <td>
                                    @if (CronService.ValidateCronExpression(schedule.Expression))
                                    {
                                        <span class="badge bg-success">Valid</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Invalid</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-warning" @onclick="() => EditSchedule(schedule)">Edit</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteSchedule(schedule.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No schedules saved yet. Create one to get started!
        </div>
    }
</div>

@code {
    private string ScheduleName = "";
    private string SelectedExpression = "* * * * * *";
    private string AddError = "";
    private List<CronSchedules> Schedules = new();

    protected override void OnInitialized()
    {
        Schedules = new List<CronSchedules>
        {
            new CronSchedules { Id = 1, Name = "Daily Backup", Expression = "0 0 * * * *" },
            new CronSchedules { Id = 2, Name = "Every Hour", Expression = "0 * * * * *" },
            new CronSchedules { Id = 3, Name = "Weekly Report", Expression = "0 9 * * 1 *" }
        };
    }

    private void OnExpressionSelected(string expression)
    {
        SelectedExpression = expression;
    }

    private void AddSchedule()
    {
        AddError = "";

        if (string.IsNullOrWhiteSpace(ScheduleName))
        {
            AddError = "Schedule name is required.";
            return;
        }

        if (!CronService.ValidateCronExpression(SelectedExpression))
        {
            AddError = "Invalid cron expression.";
            return;
        }

        var newSchedule = new CronSchedules
        {
            Id = Schedules.Count > 0 ? Schedules.Max(s => s.Id) + 1 : 1,
            Name = ScheduleName,
            Expression = SelectedExpression
        };

        Schedules.Add(newSchedule);
        ScheduleName = "";
    }

    private void EditSchedule(CronSchedules schedule)
    {
        ScheduleName = schedule.Name;
        SelectedExpression = schedule.Expression;
        DeleteSchedule(schedule.Id);
    }

    private void DeleteSchedule(int id)
    {
        Schedules = Schedules.Where(s => s.Id != id).ToList();
    }

    public class CronSchedules
    {
        public int Id { get; set; }
        public string Name { get; set; }
        public string Expression { get; set; }
    }
}

<style>
    .schedule-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
    }

    .editor-wrapper {
        margin-bottom: 40px;
    }

